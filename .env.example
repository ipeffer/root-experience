# Core
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,it

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional admin allowlist for Supabase-authenticated users, comma-separated
ADMIN_ALLOWED_EMAILS=
# Temporary MVP fallback protection for /admin (replace with dedicated Supabase Auth admin login)
ADMIN_DASHBOARD_PASSWORD=
# Optional default source tag for submissions when not provided by UI
SUBMISSIONS_SOURCE_DEFAULT=website

# Notifications: Resend
# Optional. If any of these are missing, email notifications are disabled.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFY_EMAIL_TO=

# Notifications: Telegram
# Optional. If any of these are missing, Telegram notifications are disabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional anti-spam / observability
FORM_RATE_LIMIT_WINDOW_SECONDS=60
FORM_RATE_LIMIT_MAX=5
LOG_LEVEL=info

# Notes:
# - Do not store real secrets in this file.
# - Production values must be configured in Vercel environment settings.
# - Keep SUPABASE_SERVICE_ROLE_KEY server-side only (never expose in NEXT_PUBLIC vars).
